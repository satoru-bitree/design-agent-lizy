# fal.ai API key — get one at https://fal.ai/dashboard/keys
# Server-only. Without this, the app falls back to the mock provider.
FAL_KEY=

# Provider mode (server-only). Optional override. Restart dev server to apply.
#
#   mock              → all mock (zero token spend)
#   fal               → all fal (errors if FAL_KEY missing)
#   <kinds>           → comma-separated allowlist; only listed items use fal,
#                       everything else stays mock. Tokens:
#                         package      (라벨 / 패키지 디자인)
#                         style_shot   (스타일 샷)
#                         short_video  (숏폼 영상)
#                         brand        (브랜드 가이드 분석)
#   <unset/blank>     → fal everywhere if FAL_KEY is set, else mock
#
# Examples:
#   AI_MODE=mock                                  # everything mock
#   AI_MODE=style_shot                            # only style shots hit fal
#   AI_MODE=package,brand                         # label + brand analysis hit fal
#   AI_MODE=package,style_shot,short_video,brand  # same as AI_MODE=fal
AI_MODE=
